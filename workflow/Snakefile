        f"{WORK}/checkpoints/gate_a_reads_availability.json",
        # M2: QC
        f"{WORK}/qc/multiqc_report.html",
        f"{WORK}/qc/assembly_qc_report.tsv",
        f"{WORK}/qc/missingness_model.json",
        # M4: Phylogeny
        f"{WORK}/phylo/core.full.aln",
        f"{WORK}/phylo/recomb_filtered.aln",
        f"{WORK}/phylo/iqtree2/ml_tree.treefile",
        # M5: ASR
        f"{WORK}/asr/origin_events.tsv",
        # M6: Step4 read-backed prn validation
        str(PROJECT_DATA_ROOT / "step4_prn_validation" / "outputs" / "bp_prn_read_validation.tsv"),
        str(PROJECT_DATA_ROOT / "step4_prn_validation" / "outputs" / "bp_prn_validation_summary.tsv"),
        str(PROJECT_DATA_ROOT / "step4_prn_validation" / "outputs" / "bp_prn_is_hotspot_results.tsv"),
        # M7: Epidemiology
        f"{WORK}/epi/ap_exposure_index.tsv",
        f"{WORK}/epi/panel_model_results.tsv",


# ── Version snapshot ─────────────────────────────────────────────────────────
rule version_snapshot:
    output:
        f"{WORK}/versions.txt"
    conda:
        "config/env/environment_tool.yml"
    shell:
        f"""
        echo "=== Version Snapshot $(date -Iseconds) ===" > {{output}}
        echo "" >> {{output}}
        echo "--- conda ---" >> {{output}}
        conda list 2>/dev/null | head -50 >> {{output}} || true
        echo "" >> {{output}}
        echo "--- key tools ---" >> {{output}}
        python --version 2>&1 >> {{output}} || true
        R --version 2>&1 | head -1 >> {{output}} || true
        snippy --version 2>&1 >> {{output}} || echo "snippy: not installed" >> {{output}}
        iqtree2 --version 2>&1 | head -1 >> {{output}} || echo "iqtree2: not installed" >> {{output}}
        raxmlng --version 2>&1 | head -1 >> {{output}} || echo "raxmlng: not installed" >> {{output}}
        gubbins --version 2>&1 >> {{output}} || echo "gubbins: not installed" >> {{output}}
        fastp --version 2>&1 >> {{output}} || echo "fastp: not installed" >> {{output}}
        kraken2 --version 2>&1 >> {{output}} || echo "kraken2: not installed" >> {{output}}
        echo "" >> {{output}}
        echo "--- git ---" >> {{output}}
        git log --oneline -1 2>/dev/null >> {{output}} || echo "not a git repo" >> {{output}}
        echo "" >> {{output}}
        echo "--- config ---" >> {{output}}
        cat {CONFIG_PATH} >> {{output}} || true
        """
