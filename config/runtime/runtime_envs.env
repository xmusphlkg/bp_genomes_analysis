# Project runtime environment configuration.
#
# This file is sourced by shell launchers under `workflow/bin/` and can be
# overridden locally via `config/runtime/runtime_envs.local.env`.
#
# Readers reproducing the project should only need to edit this config (or the
# local override) instead of patching script internals.

PROJECT_CONDA_ROOT="${PROJECT_CONDA_ROOT:-$HOME/miniforge3}"
PROJECT_CONDA_EXE="${PROJECT_CONDA_EXE:-$PROJECT_CONDA_ROOT/bin/conda}"

PROJECT_ENV_BIO_TOOLS_NAME="${PROJECT_ENV_BIO_TOOLS_NAME:-pertussis-bio-tools}"
PROJECT_ENV_BIO_TOOLS_PREFIX="${PROJECT_ENV_BIO_TOOLS_PREFIX:-$PROJECT_CONDA_ROOT/envs/pertussis-bio-tools}"

PROJECT_ENV_PHYLO_NAME="${PROJECT_ENV_PHYLO_NAME:-pertussis-prn-global-bio}"
PROJECT_ENV_PHYLO_PREFIX="${PROJECT_ENV_PHYLO_PREFIX:-$PROJECT_CONDA_ROOT/envs/pertussis-prn-global-bio}"

PROJECT_ENV_R_NAME="${PROJECT_ENV_R_NAME:-pertussis-prn-global-r}"
PROJECT_ENV_R_PREFIX="${PROJECT_ENV_R_PREFIX:-$PROJECT_CONDA_ROOT/envs/pertussis-prn-global-r}"

PROJECT_CONDA_NO_PLUGINS="${PROJECT_CONDA_NO_PLUGINS:-true}"
PROJECT_CONDA_SOLVER="${PROJECT_CONDA_SOLVER:-classic}"

# Externalized data root for large, reproducible workflow/module outputs.
# Active code should write under ${PERTUSSIS_PROJECT_DATA_ROOT}, not repo-root
# outputs/ or modules/*/outputs.
_RUNTIME_ENVS_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
_RUNTIME_ENVS_REPO_ROOT="$(cd "${_RUNTIME_ENVS_DIR}/../.." && pwd)"
PERTUSSIS_DATA_ROOT="${PERTUSSIS_DATA_ROOT:-${_RUNTIME_ENVS_REPO_ROOT}/pertussis_data}"
PERTUSSIS_PROJECT_DATA_ROOT="${PERTUSSIS_PROJECT_DATA_ROOT:-${PERTUSSIS_DATA_ROOT}/pertussis_gene}"
unset _RUNTIME_ENVS_DIR _RUNTIME_ENVS_REPO_ROOT
