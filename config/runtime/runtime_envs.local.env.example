# Optional local override for machine-specific runtime environment paths.
#
# Copy to `config/runtime/runtime_envs.local.env` and edit as needed.

PROJECT_CONDA_ROOT="$HOME/miniforge3"
PROJECT_CONDA_EXE="$PROJECT_CONDA_ROOT/bin/conda"

PROJECT_ENV_BIO_TOOLS_PREFIX="$PROJECT_CONDA_ROOT/envs/pertussis-bio-tools"
PROJECT_ENV_PHYLO_PREFIX="$PROJECT_CONDA_ROOT/envs/pertussis-prn-global-bio"
PROJECT_ENV_R_PREFIX="$PROJECT_CONDA_ROOT/envs/pertussis-prn-global-r"

_RUNTIME_ENVS_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
_RUNTIME_ENVS_REPO_ROOT="$(cd "${_RUNTIME_ENVS_DIR}/../.." && pwd)"
PERTUSSIS_DATA_ROOT="${PERTUSSIS_DATA_ROOT:-${_RUNTIME_ENVS_REPO_ROOT}/pertussis_data}"
PERTUSSIS_PROJECT_DATA_ROOT="${PERTUSSIS_PROJECT_DATA_ROOT:-${PERTUSSIS_DATA_ROOT}/pertussis_gene}"
unset _RUNTIME_ENVS_DIR _RUNTIME_ENVS_REPO_ROOT
